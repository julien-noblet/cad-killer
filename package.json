{
  "name": "cad-killer",
  "version": "1.0.1",
  "description": "Visionneur de carte pour logisticiens pressés",
  "main": "index.html",
  "packageManager": "bun@1.3.11",
  "engines": {
    "node": ">=20",
    "bun": ">=1.3.11"
  },
  "scripts": {
    "dev": "node ./node_modules/next/dist/bin/next dev -p 9000",
    "build": "node ./node_modules/next/dist/bin/next build",
    "lint": "npm run lint:js && npm run lint:scss && npm run lint:prettier",
    "lint:js": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "lint:scss": "stylelint '**/*.scss'",
    "lint:scss:fix": "stylelint '**/*.scss' --fix",
    "lint:prettier": "prettier --check .",
    "lint:prettier:fix": "prettier --write .",
    "update-screenshots": "node --experimental-vm-modules node_modules/jest/bin/jest.js -u"
  },
  "lint-staged": {
    "*.js": ["prettier --write --insert-pragma"],
    "*.json": ["prettier --parser json --write"],
    "src/**.json": ["prettier --parser json --write"],
    "src/**/*.js": ["prettier --write"],
    "src/*.js": ["prettier --write"],
    "src/**/*.ts": ["prettier --write"],
    "app/**/*.{ts,tsx}": ["prettier --write"]
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/julien-noblet/cad-killer.git"
  },
  "keywords": [
    "osm"
  ],
  "author": "Julien Noblet",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/julien-noblet/cad-killer/issues"
  },
  "homepage": "https://github.com/julien-noblet/cad-killer",
  "devDependencies": {
    "@babel/core": "7.29.0",
    "@babel/eslint-parser": "7.28.6",
    "@babel/preset-env": "7.29.2",
    "@babel/preset-typescript": "7.28.5",
    "@eslint/js": "^9.39.1",
    "@types/leaflet": "1.9.21",
    "@types/react": "19.2.14",
    "commitizen": "4.3.1",
    "cssnano": "7.1.3",
    "cz-conventional-changelog": "3.3.0",
    "eslint": "9.39.4",
    "eslint-config-next": "^16.2.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-react": "7.37.5",
    "globals": "^17.0.0",
    "husky": "9.1.7",
    "jest": "^30.0.0",
    "jest-image-snapshot": "6.5.2",
    "jest-puppeteer": "11.0.0",
    "lint-staged": "16.4.0",
    "postcss": "8.5.8",
    "postcss-import": "16.1.1",
    "postcss-preset-env": "11.2.0",
    "prettier": "3.8.1",
    "puppeteer": "24.40.0",
    "sass": "^1.71.1",
    "stylelint": "^16.26.1",
    "stylelint-config-standard-scss": "^16.0.0",
    "tmp": "^0.2.5",
    "typescript": "5.9.2"
  },
  "dependencies": {
    "@fontsource-variable/open-sans": "^5.2.7",
    "leaflet": "1.9.4",
    "leaflet-ajax": "2.1.0",
    "leaflet-dialog": "1.0.5",
    "leaflet-draw": "1.0.4",
    "leaflet-hash": "0.2.1",
    "leaflet-modal": "0.2.0",
    "leaflet-plugins": "3.4.0",
    "leaflet.browser.print": "2.0.2",
    "leaflet.photon": "0.9.2",
    "material-design-iconic-font": "2.2.0",
    "next": "15.5.0",
    "react": "19.1.0",
    "react-dom": "19.1.0"
  },
  "jest": {
    "moduleNameMapper": {
      "\\.(jpg|jpeg|png|gif|eot|otf|webp|svg|ttf|woff|woff2|mp4|webm|wav|mp3|m4a|aac|oga)$": "<rootDir>/__mocks__/fileMock.js",
      "\\.(css|less)$": "<rootDir>/__mocks__/styleMock.js"
    },
    "transform": {
      "^.+\\.[jt]sx?$": [
        "babel-jest",
        {
          "presets": [
            [
              "@babel/preset-env",
              {
                "targets": {
                  "node": "current"
                },
                "modules": "commonjs"
              }
            ],
            "@babel/preset-typescript"
          ]
        }
      ]
    },
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js",
      "jsx",
      "json",
      "node"
    ],
    "verbose": true,
    "bail": false,
    "collectCoverage": false,
    "modulePathIgnorePatterns": [
      "sandbox",
      "node_modules"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/jest-setup.js"
    ],
    "preset": "jest-puppeteer",
    "globalSetup": "./setup.js",
    "globalTeardown": "./teardown.js",
    "testEnvironment": "./puppeteer_environment.js",
    "globals": {
      "window": true
    }
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "patchedDependencies": {
    "material-design-iconic-font@2.2.0": "patches/material-design-iconic-font@2.2.0.patch"
  }
}
